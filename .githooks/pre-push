#!/usr/bin/env bash
set -euo pipefail

red='\033[0;31m'; yellow='\033[1;33m'; green='\033[0;32m'; nc='\033[0m'

if command -v gitleaks >/dev/null 2>&1; then
  if ! gitleaks git --redact --config .gitleaks.toml --no-banner >/dev/null 2>&1; then
    echo -e "${red}✗ Push blocked:${nc} gitleaks found potential secrets in repository history."
    echo -e "Run: gitleaks git --redact --config .gitleaks.toml"
    exit 1
  fi
else
  echo -e "${yellow}! gitleaks not installed; running basic fallback scan.${nc}"
  suspect=$(git ls-files | grep -Ei '(\.env$|\.pem$|\.key$|token|secret|credential|openclaw\.json$)' || true)
  if [[ -n "$suspect" ]]; then
    echo -e "${red}✗ Push blocked:${nc} suspicious tracked filenames detected:"
    echo "$suspect"
    exit 1
  fi
fi

echo -e "${green}✓ pre-push checks passed${nc}"
