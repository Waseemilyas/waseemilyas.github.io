#!/usr/bin/env bash
set -euo pipefail
# naz-hardening pre-commit
red='\033[0;31m'; green='\033[0;32m'; nc='\033[0m'
blocked_paths_regex='(^|/)(\.openclaw/|memory/|MEMORY\.md$|USER\.md$|openclaw\.json$|.*\.token$|.*token.*|.*secret.*|.*credential.*|ms-graph-token\.json$|msgraph-calendar-token\.json$)'
staged_files=$(git diff --cached --name-only --diff-filter=ACM || true)
if [[ -n "$staged_files" ]] && echo "$staged_files" | grep -E "$blocked_paths_regex" >/dev/null; then
  echo -e "${red}✗ Commit blocked:${nc} staged files include sensitive paths."
  echo "$staged_files" | grep -E "$blocked_paths_regex" || true
  exit 1
fi
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --staged --redact --config .gitleaks.toml --no-banner >/dev/null 2>&1 || { echo -e "${red}✗ Commit blocked:${nc} gitleaks found potential secrets."; exit 1; }
fi
patch=$(git diff --cached -U0 || true)
secret_regex='(sk-[A-Za-z0-9_-]{20,}|xox[baprs]-[A-Za-z0-9-]{20,}|AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}|-----BEGIN (RSA|EC|OPENSSH|PRIVATE) KEY-----|OPENROUTER_API_KEY\s*=|(?i)(api[_-]?key|secret|token|password)\s*[:=]\s*['"'"']?[A-Za-z0-9_\-]{16,})'
echo "$patch" | grep -E "$secret_regex" >/dev/null && { echo -e "${red}✗ Commit blocked:${nc} regex scanner detected possible secret material."; exit 1; }
echo -e "${green}✓ pre-commit checks passed${nc}"
