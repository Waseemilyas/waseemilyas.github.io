---
layout: base.njk
title: "Notes"
description: "Notes and writing by Waseem Ilyas."
permalink: "/notes/"
eleventyExcludeFromCollections: true
---
<section class="essay section" aria-label="Notes">
  <div class="shell">
    <div class="casehead" data-cal>
      <span class="ref">NOTES</span>
      <h1>Notes</h1>
      <p class="kick">Occasional writing on AI, automation, and building useful things.</p>
    </div>

    {%- if collections.notes and collections.notes.length %}
    <div class="notes-list" data-cal>
      {%- for note in collections.notes %}
      <article class="note-item">
        <span class="date"><time datetime="{{ note.date | isoDate }}">{{ note.date | readableDate }}</time></span>
        <h2><a href="{{ note.url }}">{{ note.data.title }}</a></h2>
        {%- if note.data.summary %}<p>{{ note.data.summary }}</p>{%- endif %}
      </article>
      {%- endfor %}
    </div>
    {%- else %}
    <div class="notes-empty" data-cal>
      <p>No notes published yet. This space is ready for the first post: a single Markdown file in <code>src/notes/</code> with a title, date, and summary is all it takes.</p>
    </div>
    {%- endif %}
  </div>
</section>
