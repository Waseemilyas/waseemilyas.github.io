---
permalink: "/sitemap.xml"
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {%- set staticUrls = ["/", "/about/", "/work/", "/automancer/", "/lab/", "/contact/"] %}
  {%- for u in staticUrls %}
  <url><loc>{{ site.url }}{{ u }}</loc></url>
  {%- endfor %}
  {%- for cs in collections.casestudies %}
  <url><loc>{{ site.url }}{{ cs.url }}</loc></url>
  {%- endfor %}
  {%- for note in collections.notes %}
  <url><loc>{{ site.url }}{{ note.url }}</loc></url>
  {%- endfor %}
</urlset>
